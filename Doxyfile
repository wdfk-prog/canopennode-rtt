# Doxygen configuration for CANopenNode RT-Thread package CI.

PROJECT_NAME           = "CANopenNode RT-Thread"
PROJECT_BRIEF          = "RT-Thread integration package for CANopenNode"
OUTPUT_DIRECTORY       = _doxygen
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = NO
OUTPUT_LANGUAGE        = English
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_IF_INCOMPLETE_DOC = YES
WARN_AS_ERROR          = NO
WARN_FORMAT            = "$file:$line: $text"
WARN_LOGFILE           =

INPUT                  = README.md \
                         README.zh-CN.md \
                         docs \
                         port \
                         examples/demo_device \
                         CANopenNode/CANopen.h \
                         CANopenNode/301 \
                         CANopenNode/303 \
                         CANopenNode/304 \
                         CANopenNode/305 \
                         CANopenNode/309 \
                         CANopenNode/storage

INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.c \
                         *.h \
                         *.md
MARKDOWN_SUPPORT       = YES
USE_MDFILE_AS_MAINPAGE = docs/doxygen-mainpage.md
RECURSIVE              = YES
EXCLUDE                = CANopenNode/.git \
                         CANopenNode/doc/html
EXCLUDE_PATTERNS       = */.git/* \
                         */_ci/* \
                         */build/* \
                         */dist/*

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO
HAVE_DOT               = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
DOT_IMAGE_FORMAT       = svg
